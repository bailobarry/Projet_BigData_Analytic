# ============================================================
# Variables d'environnement – ELOQUENT Cultural Robustness
# ============================================================
# Copiez ce fichier en `.env` et renseignez votre clé API.
#
# Groq Cloud : https://console.groq.com/keys (gratuit)
# ============================================================

# --- Groq Cloud (API cloud) ---
# Option A: une seule cle
GROQ_API_KEY=votre_cle_groq_ici

# Option B: plusieurs cles (prioritaire si renseigne)
# Separateurs acceptes: virgule, point-virgule, retour ligne
# GROQ_API_KEYS=cle_compte_1,cle_compte_2,cle_compte_3

# Limite locale (requests/min) appliquee par cle cote provider
# Ajustez selon votre plan API (ex: 1500)
GROQ_RPM_PER_KEY=1500

